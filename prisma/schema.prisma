// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  emoji        String
  keywords     String   // comma-separated keywords for query
  amazonNode   String?  // Amazon bestsellers node ID
  aliexpressCat String? // AliExpress category slug
  shopeeCat    String?  // Shopee keyword/category slug
  tokopediaCat String?  // Tokopedia category slug
  lazadaCat    String?  // Lazada category slug
  order        Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AffiliateTag {
  id          String   @id @default(cuid())
  marketplace String   @unique  // shopee, tokopedia, lazada, aliexpress
  tag         String   // affiliate tag / ID
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
